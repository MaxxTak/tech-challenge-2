# Database Connection Settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_DATABASE=tech

# Kafka Message Broker Settings
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_BROKER_HOSTS=localhost:9092

# AWS / S3 Settings (used by the streaming Bronze consumer)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_SESSION_TOKEN=your_session_token   # required for temporary STS credentials (ASIA* keys); omit for long-lived IAM keys
AWS_VERIFY_SSL=false    # set to true in production
AWS_BUCKET=postech-fase2-datalake
PROJECT_ENVIRONMENT=dev
BRONZE_BASE_PATH=bronze
BRONZE_TARGET_NAME=uf
REGISTER_CATALOG=false #if needs to register catalog (table)